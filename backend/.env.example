# ============================================================
# Skynity ISP — Backend standalone .env (rarely used)
# ------------------------------------------------------------
# If you deploy with docker-compose (recommended), use the
# ROOT-level .env at ../.env instead. See `../.env.example`.
#
# This file is ONLY needed when running the backend directly
# on the host (outside Docker), e.g. for local development.
# ============================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skynity
DB_USER=skynity
DB_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# --- MikroTik (optional — add via UI after first login) ---
MIKROTIK_HOST=
MIKROTIK_PORT=443
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=
MIKROTIK_USE_SSL=true
MIKROTIK_REJECT_UNAUTHORIZED=false

# --- SNMP ---
SNMP_ENABLED=false

# --- Payments (Send Money; portal + bot — optional override vs System Settings) ---
BKASH_NUMBER=01811871332
BKASH_TYPE=personal
NAGAD_NUMBER=01811871332
NAGAD_TYPE=personal

# --- Security (generate with: openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_at_least_16_chars_long_random_string
SESSION_SECRET=CHANGE_ME_another_long_random_string_at_least_16

# --- App ---
APP_NAME=Skynity ISP
APP_TIMEZONE=Asia/Dhaka
CURRENCY=BDT
CURRENCY_SYMBOL=৳
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# --- Public base URL (used for router /tool/fetch downloads) ---
PUBLIC_BASE_URL=
