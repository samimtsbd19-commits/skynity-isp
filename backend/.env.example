# ============================================
# Skynity ISP — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Database (MySQL) ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=skynity
DB_USER=skynity
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Telegram Bot ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated Telegram numeric user IDs of admins
# Get your ID from @userinfobot
TELEGRAM_ADMIN_IDS=123456789,987654321

# --- MikroTik Router (default/main) ---
# If MikroTik is behind a WireGuard tunnel, use the tunnel IP
MIKROTIK_HOST=192.168.50.1
MIKROTIK_PORT=443
MIKROTIK_USERNAME=api-user
MIKROTIK_PASSWORD=CHANGE_ME_MIKROTIK_PASSWORD
MIKROTIK_USE_SSL=true
MIKROTIK_REJECT_UNAUTHORIZED=false

# --- SNMP (Phase 4 live bandwidth) ---
# Optional. If disabled, monitoring falls back to REST counters.
SNMP_ENABLED=false
SNMP_COMMUNITY=public
SNMP_PORT=161
SNMP_VERSION=2c
SNMP_TIMEOUT_MS=2500

# --- Payment Settings ---
BKASH_NUMBER=01XXXXXXXXX
BKASH_TYPE=personal
NAGAD_NUMBER=01XXXXXXXXX
NAGAD_TYPE=personal

# --- Security ---
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
SESSION_SECRET=another_long_random_string_here

# --- App Settings ---
APP_NAME=Skynity ISP
APP_TIMEZONE=Asia/Dhaka
CURRENCY=BDT
CURRENCY_SYMBOL=৳

# --- File Uploads ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=5
