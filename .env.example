# ============================================================
# Skynity ISP — Root .env (for docker-compose)
# ------------------------------------------------------------
# Copy this file to `.env` and fill in the CHANGE_ME_* values.
#
# Only the values with "← REQUIRED" are mandatory for first boot.
# Everything else has a sensible default or can be configured
# later from the web admin panel (System Settings → Routers).
# ============================================================

# --- Domain & HTTPS ---
# The public domain pointing to your VPS (A record).
# Caddy will auto-obtain a Let's Encrypt certificate for it.
DOMAIN=wifi.skynity.org                         # ← REQUIRED
ACME_EMAIL=admin@skynity.org                    # email used by Let's Encrypt

# Full public URL your admin panel is reachable at.
# Used for generating router-fetchable config download links.
PUBLIC_BASE_URL=https://wifi.skynity.org

# --- Runtime ---
NODE_ENV=production
LOG_LEVEL=info

# --- Database (MySQL) ---
DB_NAME=skynity
DB_USER=skynity
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD           # ← REQUIRED
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD        # ← REQUIRED

# --- Telegram Bot ---
# Create one via @BotFather on Telegram, then paste the token here.
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # ← REQUIRED

# Comma-separated numeric Telegram IDs of admins who should receive
# order notifications in Telegram. Get yours from @userinfobot.
# Leave empty if you don't want Telegram notifications yet.
TELEGRAM_ADMIN_IDS=123456789

# --- MikroTik Router ---
# Optional for first deploy. You can add routers from the web UI
# after first login (Routers → Add). If you want to pre-seed your
# primary router via env, fill these; otherwise leave blank.
MIKROTIK_HOST=
MIKROTIK_PORT=443
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=
MIKROTIK_USE_SSL=true
MIKROTIK_REJECT_UNAUTHORIZED=false

# --- SNMP (for live bandwidth graphs) ---
SNMP_ENABLED=false
SNMP_COMMUNITY=public
SNMP_PORT=161
SNMP_VERSION=2c
SNMP_TIMEOUT_MS=2500

# --- Payment Instructions (shown to customers in the Telegram bot) ---
BKASH_NUMBER=01XXXXXXXXX
BKASH_TYPE=personal
NAGAD_NUMBER=01XXXXXXXXX
NAGAD_TYPE=personal

# --- Security (MUST change from defaults) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_with_openssl_rand_hex_32_at_least_32_chars_long      # ← REQUIRED
SESSION_SECRET=CHANGE_ME_with_openssl_rand_hex_32_at_least_32_chars_long  # ← REQUIRED

# --- Branding / Locale ---
APP_NAME=Skynity ISP
APP_TIMEZONE=Asia/Dhaka
CURRENCY=BDT
CURRENCY_SYMBOL=৳

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=5
