{
	auto_https off
}

:80 {
	encode zstd gzip

	reverse_proxy frontend:80 {
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto http
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
		-Server
	}

	log {
		output stdout
		format console
	}
}
